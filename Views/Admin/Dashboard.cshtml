@model CoffeeShopManager.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Dashboard Admin";
}

<style>
    .dashboard-page {
        min-height: 100vh;
        background: #f5f1e8;
        padding: 45px 30px 70px;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .dashboard-sheet {
        max-width: 1200px;
        margin: 0 auto;
        background: #f8f6ef;
        border: 4px solid #4d5c4f;
        padding: 36px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    }

    .dashboard-title {
        text-align: center;
        color: #8f2f24;
        font-size: 46px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .dashboard-line {
        border-bottom: 4px dashed #8f2f24;
        margin: 0 auto 32px;
        width: 92%;
    }

    .dashboard-subtitle {
        color: #28404a;
        font-size: 24px;
        font-weight: 900;
        margin: 34px 0 18px;
        text-transform: uppercase;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
    }

    .stat-card {
        background: #fffaf0;
        border: 3px solid #4d5c4f;
        padding: 22px 18px;
        text-align: center;
        min-height: 145px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .stat-label {
        color: #28404a;
        font-size: 17px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 12px;
    }

    .stat-number {
        color: #8f2f24;
        font-size: 38px;
        font-weight: 900;
    }

    .stat-money {
        color: #8f2f24;
        font-size: 30px;
        font-weight: 900;
    }

    .quick-actions {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        margin-top: 26px;
        justify-content: center;
    }

    .quick-btn {
        min-width: 210px;
        height: 56px;
        border: 4px solid #4d5c4f;
        color: #26404a;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 17px;
        font-weight: 900;
        text-transform: uppercase;
        background: transparent;
    }

        .quick-btn:hover {
            background: #e9e3d7;
            color: #26404a;
        }

    .main-btn {
        background: #3d5343;
        color: white;
    }

        .main-btn:hover {
            background: #2f4335;
            color: white;
        }

    .table-wrap {
        width: 100%;
        overflow-x: auto;
    }

    .order-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 14px;
    }

        .order-table th {
            background: #3d5343;
            color: white;
            padding: 14px;
            text-align: center;
            text-transform: uppercase;
            font-size: 15px;
        }

        .order-table td {
            border-bottom: 3px solid #4d5c4f;
            padding: 15px 10px;
            text-align: center;
            color: #28404a;
            font-weight: 800;
            vertical-align: middle;
        }

    .price-text {
        color: #8f2f24;
        font-weight: 900;
        white-space: nowrap;
    }

    .status-badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        font-weight: 900;
        background: #fff3cd;
        color: #856404;
        border: 1px solid #d6a700;
        white-space: nowrap;
    }

    .status-cancelled {
        background: #fdecea;
        color: #b42318;
        border-color: #b42318;
    }

    .status-done {
        background: #e6f4ea;
        color: #1f7a3b;
        border-color: #1f7a3b;
    }

    .detail-btn {
        display: inline-block;
        padding: 9px 16px;
        background: #3d5343;
        color: white;
        text-decoration: none;
        font-weight: 900;
        border-radius: 6px;
        white-space: nowrap;
    }

        .detail-btn:hover {
            background: #2f4335;
            color: white;
        }

    @@media (max-width: 1000px) {
        .stat-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 600px) {
        .dashboard-sheet {
            padding: 24px;
        }

        .dashboard-title {
            font-size: 34px;
        }

        .stat-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="dashboard-page">
    <div class="dashboard-sheet">
        <h1 class="dashboard-title">Dashboard Admin</h1>
        <div class="dashboard-line"></div>

        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-label">Tổng sản phẩm</div>
                <div class="stat-number">@Model.TongSanPham</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Sản phẩm đang hiện</div>
                <div class="stat-number">@Model.SanPhamDangHien</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Sản phẩm đang ẩn</div>
                <div class="stat-number">@Model.SanPhamDangAn</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Tổng đơn hàng</div>
                <div class="stat-number">@Model.TongDonHang</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Đơn chờ xử lý</div>
                <div class="stat-number">@Model.DonChoXuLy</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Đơn hoàn thành</div>
                <div class="stat-number">@Model.DonHoanThanh</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Đơn đã hủy</div>
                <div class="stat-number">@Model.DonDaHuy</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Doanh thu tạm tính</div>
                <div class="stat-money">@Model.DoanhThuTamTinh.ToString("N0") Đ</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Tổng tài khoản</div>
                <div class="stat-number">@Model.TongNguoiDung</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Tài khoản User</div>
                <div class="stat-number">@Model.TongTaiKhoanUser</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Tài khoản Admin</div>
                <div class="stat-number">@Model.TongTaiKhoanAdmin</div>
            </div>

            <div class="stat-card">
                <div class="stat-label">Đơn còn xử lý</div>
                <div class="stat-number">@Model.DonChoXuLy</div>
            </div>
        </div>

        <div class="quick-actions">
            <a asp-controller="Admin" asp-action="Index" class="quick-btn main-btn">
                Quản lý sản phẩm
            </a>

            <a asp-controller="DonHang" asp-action="Index" class="quick-btn">
                Quản lý đơn hàng
            </a>

            <a asp-controller="Home" asp-action="Index" class="quick-btn">
                Về trang chủ
            </a>
        </div>

        <h2 class="dashboard-subtitle">Đơn hàng gần đây</h2>

        @if (Model.DonHangGanDay == null || !Model.DonHangGanDay.Any())
        {
            <p style="text-align:center; font-weight:900; color:#28404a; padding:25px;">
                Chưa có đơn hàng nào.
            </p>
        }
        else
        {
            <div class="table-wrap">
                <table class="order-table">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Khách hàng</th>
                            <th>Tài khoản</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Xem</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model.DonHangGanDay)
                        {
                            <tr>
                                <td>#@item.MaDonHang</td>

                                <td>
                                    @item.NgayDat.ToString("dd/MM/yyyy HH:mm")
                                </td>

                                <td>
                                    @item.TenKhachHang
                                </td>

                                <td>
                                    @(item.NguoiDung?.HoTen ?? "Khách / Chưa gán")
                                </td>

                                <td class="price-text">
                                    @item.TongTien.ToString("N0") Đ
                                </td>

                                <td>
                                    @if (item.TrangThai == "Đã hủy")
                                    {
                                        <span class="status-badge status-cancelled">
                                            @item.TrangThai
                                        </span>
                                    }
                                    else if (item.TrangThai == "Hoàn thành")
                                    {
                                        <span class="status-badge status-done">
                                            @item.TrangThai
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge">
                                            @item.TrangThai
                                        </span>
                                    }
                                </td>

                                <td>
                                    <a asp-controller="DonHang"
                                       asp-action="Details"
                                       asp-route-madonhang="@item.MaDonHang"
                                       class="detail-btn">
                                        Xem
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>