@model List<CoffeeShopManager.ViewModels.GioHangItemViewModel>

@{
    ViewData["Title"] = "Giỏ hàng";

    decimal tongTien = ViewBag.TongTien ?? 0;
    int tongSoLuong = ViewBag.TongSoLuong ?? 0;
}

<style>
    .cart-page {
        min-height: 100vh;
        background: #f5f1e8;
        padding: 45px 30px 70px;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .cart-sheet {
        max-width: 1100px;
        margin: 0 auto;
        background: #f8f6ef;
        border: 4px solid #4d5c4f;
        padding: 36px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    }

    .cart-title {
        text-align: center;
        color: #8f2f24;
        font-size: 44px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .cart-line {
        border-bottom: 4px dashed #8f2f24;
        margin: 0 auto 30px;
        width: 92%;
    }

    .success-message {
        background: #e6f4ea;
        color: #1f7a3b;
        border: 2px solid #1f7a3b;
        padding: 14px 18px;
        margin-bottom: 24px;
        font-weight: 900;
    }

    .empty-cart {
        text-align: center;
        color: #28404a;
        font-size: 22px;
        font-weight: 900;
        padding: 40px 10px;
    }

    .cart-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

        .cart-table th {
            background: #3d5343;
            color: white;
            padding: 14px;
            text-align: center;
            font-size: 16px;
            text-transform: uppercase;
        }

        .cart-table td {
            border-bottom: 3px solid #4d5c4f;
            padding: 16px 10px;
            text-align: center;
            vertical-align: middle;
            color: #28404a;
            font-weight: 800;
        }

    .cart-product {
        display: flex;
        align-items: center;
        gap: 14px;
        text-align: left;
    }

    .cart-img {
        width: 90px;
        height: 70px;
        border: 2px solid #4d5c4f;
        background: #fff;
        object-fit: cover;
    }

    .no-img {
        width: 90px;
        height: 70px;
        border: 2px solid #4d5c4f;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        color: #777;
    }

    .qty-form {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .qty-input {
        width: 80px;
        height: 38px;
        border: 2px solid #4d5c4f;
        text-align: center;
        font-weight: 900;
        background: #fffaf0;
    }

    .small-btn {
        height: 38px;
        border: none;
        padding: 0 14px;
        font-weight: 900;
        cursor: pointer;
        color: white;
        background: #5c6a75;
    }

        .small-btn:hover {
            background: #49545d;
        }

    .delete-btn {
        background: #dc3545;
    }

        .delete-btn:hover {
            background: #b92a37;
        }

    .cart-summary {
        margin-top: 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
    }

    .summary-text {
        color: #28404a;
        font-size: 21px;
        font-weight: 900;
    }

    .summary-price {
        color: #8f2f24;
        font-size: 28px;
        font-weight: 900;
    }

    .cart-actions {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
    }

    .cart-btn {
        min-width: 150px;
        height: 54px;
        border: 4px solid #4d5c4f;
        background: transparent;
        color: #26404a;
        font-size: 17px;
        font-weight: 900;
        text-transform: uppercase;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

        .cart-btn:hover {
            background: #e9e3d7;
            color: #26404a;
        }

    .checkout-btn {
        background: #3d5343;
        color: white;
    }

        .checkout-btn:hover {
            background: #2f4335;
            color: white;
        }

    .clear-btn {
        background: #dc3545;
        border-color: #dc3545;
        color: white;
    }

        .clear-btn:hover {
            background: #b92a37;
            color: white;
        }

    @@media (max-width: 768px) {
        .cart-sheet {
            padding: 22px;
        }

        .cart-title {
            font-size: 32px;
        }

        .cart-table {
            font-size: 14px;
        }

        .cart-product {
            flex-direction: column;
            text-align: center;
        }

        .cart-summary {
            flex-direction: column;
            align-items: stretch;
        }

        .cart-actions {
            justify-content: center;
        }
    }
</style>

<div class="cart-page">
    <div class="cart-sheet">
        <h1 class="cart-title">Giỏ hàng</h1>
        <div class="cart-line"></div>

        @if (TempData["Success"] != null)
        {
            <div class="success-message">
                @TempData["Success"]
            </div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="empty-cart">
                Giỏ hàng hiện đang trống.
            </div>

            <div class="cart-actions" style="justify-content:center;">
                <a asp-controller="Home" asp-action="Index" class="cart-btn">
                    ← Tiếp tục chọn món
                </a>
            </div>
        }
        else
        {
            <table class="cart-table">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Giá</th>
                        <th>Số lượng</th>
                        <th>Thành tiền</th>
                        <th>Xóa</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var imagePath = "";

                        if (string.IsNullOrWhiteSpace(item.HinhAnh))
                        {
                            imagePath = "";
                        }
                        else if (item.HinhAnh.StartsWith("/") || item.HinhAnh.StartsWith("http"))
                        {
                            imagePath = item.HinhAnh;
                        }
                        else
                        {
                            imagePath = Url.Content("~/images/" + item.HinhAnh);
                        }

                        <tr>
                            <td>
                                <div class="cart-product">
                                    @if (!string.IsNullOrWhiteSpace(imagePath))
                                    {
                                        <img src="@imagePath" alt="@item.TenSP" class="cart-img" />
                                    }
                                    else
                                    {
                                        <div class="no-img">Không ảnh</div>
                                    }

                                    <span>@item.TenSP</span>
                                </div>
                            </td>

                            <td>@item.Gia.ToString("N0") Đ</td>

                            <td>
                                <form asp-controller="GioHang" asp-action="CapNhat" method="post" class="qty-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.MaSP" />
                                    <input type="number" name="soLuong" value="@item.SoLuong" min="1" class="qty-input" />
                                    <button type="submit" class="small-btn">Cập nhật</button>
                                </form>
                            </td>

                            <td>@item.ThanhTien.ToString("N0") Đ</td>

                            <td>
                                <form asp-controller="GioHang" asp-action="Xoa" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.MaSP" />
                                    <button type="submit" class="small-btn delete-btn">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="cart-summary">
                <div>
                    <div class="summary-text">
                        Tổng số lượng: @tongSoLuong
                    </div>

                    <div class="summary-price">
                        Tổng tiền: @tongTien.ToString("N0") Đ
                    </div>
                </div>

                <div class="cart-actions">
                    <a asp-controller="Home" asp-action="Index" class="cart-btn">
                        ← Chọn thêm
                    </a>

                    <form asp-controller="GioHang" asp-action="XoaTatCa" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="cart-btn clear-btn">
                            Xóa tất cả
                        </button>
                    </form>

                    <a asp-controller="GioHang" asp-action="DatHang" class="cart-btn checkout-btn">
                        Đặt hàng
                    </a>
                </div>
            </div>
        }
    </div>
</div>