@model IEnumerable<CoffeeShopManager.Models.DonHang>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<style>
    .my-order-page {
        min-height: 100vh;
        background: #f5f1e8;
        padding: 45px 30px 70px;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .my-order-sheet {
        max-width: 1100px;
        margin: 0 auto;
        background: #f8f6ef;
        border: 4px solid #4d5c4f;
        padding: 36px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    }

    .order-title {
        text-align: center;
        color: #8f2f24;
        font-size: 42px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .order-line {
        border-bottom: 4px dashed #8f2f24;
        margin: 0 auto 30px;
        width: 92%;
    }

    .empty-order {
        text-align: center;
        color: #28404a;
        font-size: 22px;
        font-weight: 900;
        padding: 40px 10px;
    }

    .order-table {
        width: 100%;
        border-collapse: collapse;
    }

        .order-table th {
            background: #3d5343;
            color: white;
            padding: 14px;
            text-align: center;
            text-transform: uppercase;
            font-size: 15px;
        }

        .order-table td {
            border-bottom: 3px solid #4d5c4f;
            padding: 16px 10px;
            text-align: center;
            color: #28404a;
            font-weight: 800;
            vertical-align: middle;
        }

    .price-text {
        color: #8f2f24;
        font-size: 20px;
        font-weight: 900;
    }

    .status-badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        background: #fff3cd;
        color: #856404;
        font-weight: 900;
        border: 1px solid #d6a700;
    }

    .detail-btn {
        display: inline-block;
        padding: 10px 18px;
        background: #3d5343;
        color: white;
        text-decoration: none;
        font-weight: 900;
        border-radius: 6px;
    }

        .detail-btn:hover {
            background: #2f4335;
            color: white;
        }

    .back-btn {
        display: inline-flex;
        margin-top: 28px;
        min-width: 170px;
        height: 52px;
        border: 4px solid #4d5c4f;
        color: #26404a;
        text-decoration: none;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        text-transform: uppercase;
    }

        .back-btn:hover {
            background: #e9e3d7;
            color: #26404a;
        }
</style>

<div class="my-order-page">
    <div class="my-order-sheet">
        <h1 class="order-title">Đơn hàng của tôi</h1>
        <div class="order-line"></div>

        @if (Model == null || !Model.Any())
        {
            <div class="empty-order">
                Bạn chưa có đơn hàng nào.
            </div>
        }
        else
        {
            <table class="order-table">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th>Tên khách</th>
                        <th>Số điện thoại</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Chi tiết</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.MaDonHang</td>
                            <td>@item.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.TenKhachHang</td>
                            <td>@item.SoDienThoai</td>
                            <td class="price-text">@item.TongTien.ToString("N0") Đ</td>
                            <td>
                                <span class="status-badge">@item.TrangThai</span>
                            </td>
                            <td>
                                <a asp-controller="DonHang"
                                   asp-action="ChiTietCuaToi"
                                   asp-route-id="@item.MaDonHang"
                                   class="detail-btn">
                                    Xem
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <a asp-controller="Home" asp-action="Index" class="back-btn">
            ← Về trang chủ
        </a>
    </div>
</div>