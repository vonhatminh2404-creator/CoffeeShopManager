@model CoffeeShopManager.Models.DonHang

@{
    ViewData["Title"] = "Chi tiết đơn hàng";

    var danhSachTrangThai = ViewBag.DanhSachTrangThai as List<string> ?? new List<string>
    {
        "Chờ xử lý",
        "Đang chuẩn bị",
        "Hoàn thành",
        "Đã hủy"
    };
}

<style>
    .order-detail-page {
        min-height: 100vh;
        background: #f5f1e8;
        padding: 45px 30px 70px;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .order-detail-sheet {
        max-width: 980px;
        margin: 0 auto;
        background: #f8f6ef;
        border: 4px solid #4d5c4f;
        padding: 36px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    }

    .detail-title {
        text-align: center;
        color: #8f2f24;
        font-size: 42px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .detail-line {
        border-bottom: 4px dashed #8f2f24;
        margin: 0 auto 30px;
        width: 92%;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 22px;
    }

    .info-row {
        margin-bottom: 18px;
    }

    .info-label {
        color: #28404a;
        font-size: 18px;
        font-weight: 900;
        margin-bottom: 8px;
    }

    .info-value {
        color: #6f7680;
        font-size: 18px;
        font-weight: 800;
        border-bottom: 3px solid #4d5c4f;
        padding: 8px 6px 12px;
        min-height: 42px;
    }

    .price-text {
        color: #8f2f24;
        font-size: 24px;
        font-weight: 900;
    }

    .status-box {
        margin-top: 25px;
        padding: 22px;
        background: #fffaf0;
        border: 3px solid #4d5c4f;
    }

    .status-title {
        color: #8f2f24;
        font-size: 23px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 16px;
    }

    .status-form {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
    }

    .status-select {
        height: 48px;
        min-width: 220px;
        border: 3px solid #4d5c4f;
        background: #fff;
        color: #28404a;
        font-weight: 900;
        padding: 0 12px;
        font-size: 17px;
    }

    .update-btn {
        height: 48px;
        border: none;
        background: #3d5343;
        color: white;
        font-weight: 900;
        padding: 0 22px;
        cursor: pointer;
        border-radius: 6px;
        text-transform: uppercase;
    }

        .update-btn:hover {
            background: #2f4335;
        }

    .product-title {
        color: #28404a;
        font-size: 24px;
        font-weight: 900;
        text-transform: uppercase;
        margin-top: 34px;
        margin-bottom: 16px;
    }

    .product-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 12px;
    }

        .product-table th {
            background: #3d5343;
            color: white;
            padding: 12px;
            text-align: center;
            text-transform: uppercase;
        }

        .product-table td {
            border-bottom: 3px solid #4d5c4f;
            padding: 14px 8px;
            text-align: center;
            font-weight: 800;
            color: #28404a;
        }

    .button-row {
        margin-top: 32px;
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
    }

    .back-btn,
    .edit-btn,
    .delete-btn {
        min-width: 150px;
        height: 52px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        text-transform: uppercase;
        border-radius: 6px;
    }

    .back-btn {
        border: 4px solid #4d5c4f;
        color: #26404a;
        background: transparent;
    }

        .back-btn:hover {
            background: #e9e3d7;
            color: #26404a;
        }

    .edit-btn {
        background: #2f6fed;
        color: white;
    }

    .delete-btn {
        background: #dc3545;
        color: white;
    }

        .edit-btn:hover,
        .delete-btn:hover {
            opacity: 0.88;
            color: white;
        }

    @@media (max-width: 700px) {
        .info-grid {
            grid-template-columns: 1fr;
        }

        .detail-title {
            font-size: 32px;
        }
    }
</style>

<div class="order-detail-page">
    <div class="order-detail-sheet">
        <h1 class="detail-title">Chi tiết đơn hàng</h1>
        <div class="detail-line"></div>

        <div class="info-grid">
            <div class="info-row">
                <div class="info-label">Mã đơn hàng:</div>
                <div class="info-value">#@Model.MaDonHang</div>
            </div>

            <div class="info-row">
                <div class="info-label">Ngày đặt:</div>
                <div class="info-value">@Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</div>
            </div>

            <div class="info-row">
                <div class="info-label">Tên khách hàng:</div>
                <div class="info-value">@Model.TenKhachHang</div>
            </div>

            <div class="info-row">
                <div class="info-label">Số điện thoại:</div>
                <div class="info-value">@Model.SoDienThoai</div>
            </div>

            <div class="info-row">
                <div class="info-label">Tài khoản đặt hàng:</div>
                <div class="info-value">@(Model.NguoiDung?.HoTen ?? "Khách / Chưa gán")</div>
            </div>

            <div class="info-row">
                <div class="info-label">Trạng thái hiện tại:</div>
                <div class="info-value">@Model.TrangThai</div>
            </div>
        </div>

        <div class="info-row">
            <div class="info-label">Ghi chú:</div>
            <div class="info-value">@(string.IsNullOrWhiteSpace(Model.GhiChu) ? "Không có" : Model.GhiChu)</div>
        </div>

        <div class="info-row">
            <div class="info-label">Tổng tiền:</div>
            <div class="info-value price-text">@Model.TongTien.ToString("N0") Đ</div>
        </div>

        <div class="status-box">
            <div class="status-title">Cập nhật trạng thái đơn hàng</div>

            <form asp-controller="DonHang"
                  asp-action="CapNhatTrangThai"
                  method="post"
                  class="status-form">
                @Html.AntiForgeryToken()

                <input type="hidden" name="madonhang" value="@Model.MaDonHang" />

                <select name="trangThai" class="status-select">
                    @foreach (var trangThai in danhSachTrangThai)
                    {
                        if (Model.TrangThai == trangThai)
                        {
                            <option value="@trangThai" selected>@trangThai</option>
                        }
                        else
                        {
                            <option value="@trangThai">@trangThai</option>
                        }
                    }
                </select>

                <button type="submit" class="update-btn">
                    Lưu trạng thái
                </button>
            </form>
        </div>

        <div class="product-title">Sản phẩm trong đơn</div>

        @if (Model.ChiTietDonHangs != null && Model.ChiTietDonHangs.Any())
        {
            <table class="product-table">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Số lượng</th>
                        <th>Giá bán</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var ct in Model.ChiTietDonHangs)
                    {
                        <tr>
                            <td>@ct.SanPham?.TenSP</td>
                            <td>@ct.SoLuong</td>
                            <td>@ct.GiaBan.ToString("N0") Đ</td>
                            <td>@((ct.GiaBan * ct.SoLuong).ToString("N0")) Đ</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p style="font-weight:900; color:#777;">
                Đơn hàng này chưa có chi tiết sản phẩm.
            </p>
        }

        <div class="button-row">
            <a asp-controller="DonHang" asp-action="Index" class="back-btn">
                ← Trở về
            </a>

            <a asp-controller="DonHang"
               asp-action="Edit"
               asp-route-madonhang="@Model.MaDonHang"
               class="edit-btn">
                Sửa
            </a>

            <a asp-controller="DonHang"
               asp-action="Delete"
               asp-route-madonhang="@Model.MaDonHang"
               class="delete-btn">
                Xóa
            </a>
        </div>
    </div>
</div>