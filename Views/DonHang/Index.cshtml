@model IEnumerable<CoffeeShopManager.Models.DonHang>

@{
    ViewData["Title"] = "Quản lý đơn hàng";

    var danhSachTrangThai = ViewBag.DanhSachTrangThai as List<string> ?? new List<string>
    {
        "Chờ xử lý",
        "Đang chuẩn bị",
        "Hoàn thành",
        "Đã hủy"
    };
}

<style>
    .order-admin-page {
        min-height: 100vh;
        background: #f5f1e8;
        padding: 45px 30px 70px;
        font-family: 'Merriweather', 'Noto Serif Display', 'Be Vietnam Pro', serif;
    }

    .order-admin-sheet {
        max-width: 1250px;
        margin: 0 auto;
        background: #f8f6ef;
        border: 4px solid #4d5c4f;
        padding: 36px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
    }

    .order-title {
        text-align: center;
        color: #8f2f24;
        font-size: 44px;
        font-weight: 900;
        text-transform: uppercase;
        margin-bottom: 18px;
    }

    .order-line {
        border-bottom: 4px dashed #8f2f24;
        margin: 0 auto 30px;
        width: 92%;
    }

    .success-message {
        background: #e6f4ea;
        color: #1f7a3b;
        border: 2px solid #1f7a3b;
        padding: 14px 18px;
        margin-bottom: 24px;
        font-weight: 900;
    }

    .error-message {
        background: #fdecea;
        color: #b42318;
        border: 2px solid #b42318;
        padding: 14px 18px;
        margin-bottom: 24px;
        font-weight: 900;
    }

    .table-wrap {
        width: 100%;
        overflow-x: auto;
    }

    .order-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1100px;
    }

        .order-table th {
            background: #3d5343;
            color: white;
            padding: 14px 10px;
            text-align: center;
            text-transform: uppercase;
            font-size: 14px;
        }

        .order-table td {
            border-bottom: 3px solid #4d5c4f;
            padding: 15px 10px;
            text-align: center;
            color: #28404a;
            font-weight: 800;
            vertical-align: middle;
        }

    .price-text {
        color: #8f2f24;
        font-size: 18px;
        font-weight: 900;
        white-space: nowrap;
    }

    .status-badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        font-weight: 900;
        background: #fff3cd;
        color: #856404;
        border: 1px solid #d6a700;
        white-space: nowrap;
    }

    .status-processing {
        background: #e7f1ff;
        color: #0b5ed7;
        border-color: #0b5ed7;
    }

    .status-done {
        background: #e6f4ea;
        color: #1f7a3b;
        border-color: #1f7a3b;
    }

    .status-cancelled {
        background: #fdecea;
        color: #b42318;
        border-color: #b42318;
    }

    .status-form {
        display: flex;
        gap: 8px;
        justify-content: center;
        align-items: center;
        flex-wrap: nowrap;
    }

    .status-select {
        height: 40px;
        min-width: 145px;
        border: 2px solid #4d5c4f;
        background: #fffaf0;
        color: #28404a;
        font-weight: 900;
        padding: 0 8px;
    }

    .update-btn {
        height: 40px;
        border: none;
        background: #3d5343;
        color: white;
        font-weight: 900;
        padding: 0 14px;
        cursor: pointer;
        border-radius: 6px;
        white-space: nowrap;
    }

        .update-btn:hover {
            background: #2f4335;
        }

    .action-btn {
        display: inline-block;
        padding: 9px 14px;
        margin: 2px;
        color: white;
        text-decoration: none;
        font-weight: 900;
        border-radius: 6px;
        white-space: nowrap;
    }

    .detail-btn {
        background: #3d5343;
    }

    .edit-btn {
        background: #2f6fed;
    }

    .delete-btn {
        background: #dc3545;
    }

    .action-btn:hover {
        opacity: 0.88;
        color: white;
    }

    .top-actions {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 25px;
    }

    .back-btn {
        min-width: 180px;
        height: 52px;
        border: 4px solid #4d5c4f;
        color: #26404a;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        text-transform: uppercase;
    }

        .back-btn:hover {
            background: #e9e3d7;
            color: #26404a;
        }

    .empty-text {
        text-align: center;
        color: #28404a;
        font-size: 22px;
        font-weight: 900;
        padding: 35px;
    }
</style>

<div class="order-admin-page">
    <div class="order-admin-sheet">
        <h1 class="order-title">Quản lý đơn hàng</h1>
        <div class="order-line"></div>

        @if (TempData["Success"] != null)
        {
            <div class="success-message">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="error-message">
                @TempData["Error"]
            </div>
        }

        <div class="top-actions">
            <a asp-controller="Admin" asp-action="Dashboard" class="back-btn">
                ← Dashboard
            </a>

            <a asp-controller="Admin" asp-action="Index" class="back-btn">
                Quản lý sản phẩm
            </a>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="empty-text">
                Chưa có đơn hàng nào.
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="order-table">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Khách hàng</th>
                            <th>Số điện thoại</th>
                            <th>Tài khoản</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Cập nhật trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            string statusClass = "";

                            if (item.TrangThai == "Đang chuẩn bị")
                            {
                                statusClass = "status-processing";
                            }
                            else if (item.TrangThai == "Hoàn thành")
                            {
                                statusClass = "status-done";
                            }
                            else if (item.TrangThai == "Đã hủy")
                            {
                                statusClass = "status-cancelled";
                            }

                            <tr>
                                <td>#@item.MaDonHang</td>

                                <td>
                                    @item.NgayDat.ToString("dd/MM/yyyy HH:mm")
                                </td>

                                <td>
                                    @item.TenKhachHang
                                </td>

                                <td>
                                    @item.SoDienThoai
                                </td>

                                <td>
                                    @(item.NguoiDung?.HoTen ?? "Khách / Chưa gán")
                                </td>

                                <td class="price-text">
                                    @item.TongTien.ToString("N0") Đ
                                </td>

                                <td>
                                    <span class="status-badge @statusClass">
                                        @item.TrangThai
                                    </span>
                                </td>

                                <td>
                                    <form asp-controller="DonHang"
                                          asp-action="CapNhatTrangThai"
                                          method="post"
                                          class="status-form">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="madonhang" value="@item.MaDonHang" />

                                        <select name="trangThai" class="status-select">
                                            @foreach (var trangThai in danhSachTrangThai)
                                            {
                                                if (item.TrangThai == trangThai)
                                                {
                                                    <option value="@trangThai" selected>@trangThai</option>
                                                }
                                                else
                                                {
                                                    <option value="@trangThai">@trangThai</option>
                                                }
                                            }
                                        </select>

                                        <button type="submit" class="update-btn">
                                            Lưu
                                        </button>
                                    </form>
                                </td>

                                <td>
                                    <a asp-controller="DonHang"
                                       asp-action="Details"
                                       asp-route-madonhang="@item.MaDonHang"
                                       class="action-btn detail-btn">
                                        Xem
                                    </a>

                                    <a asp-controller="DonHang"
                                       asp-action="Edit"
                                       asp-route-madonhang="@item.MaDonHang"
                                       class="action-btn edit-btn">
                                        Sửa
                                    </a>

                                    <a asp-controller="DonHang"
                                       asp-action="Delete"
                                       asp-route-madonhang="@item.MaDonHang"
                                       class="action-btn delete-btn">
                                        Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>